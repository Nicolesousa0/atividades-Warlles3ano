char arquivoAtual[20];

typedef struct {
    int id;
    char nome[50], infoExtra[20];
    float valor;
} Registro;

typedef struct {
    int id;
    char nome[50];
    char professor[50];
    int cargaHoraria;
} Disciplina;

typedef struct {
    int id;
    int alunoID;
    int disciplinaID;
    float nota;
} Matricula;

typedef struct {
    int id;
