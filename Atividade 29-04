} Professor;

void limparBuffer() {
    int c;
    while ((c = getchar()) != '\n' && c != EOF);
}

int gerarProximoID() {
    FILE *f = fopen(arquivoAtual, "r");
    if (f == NULL) return 1;
    int id, maxID = 0;
    char linha[200];
    while (fgets(linha, sizeof(linha), f)) {
        if (sscanf(linha, "%d|", &id) == 1) {
            if (id > maxID) maxID = id;
        }
    }
    fclose(f);
    return maxID + 1;
}

void adicionar(char *tipo, char *labelExtra) {
    Registro r;
    char confirma;
    r.id = gerarProximoID();

    printf("\n==================================\n");
    printf("    CADASTRAR %s\n", tipo);
    printf("==================================\n");
    printf("ID GERADO: %d (Automatico)\n", r.id);
    
    printf("Nome: "); fgets(r.nome, 50, stdin);
    r.nome[strcspn(r.nome, "\n")] = 0;
    
    printf("%s: ", labelExtra); fgets(r.infoExtra, 20, stdin);
    r.infoExtra[strcspn(r.infoExtra, "\n")] = 0;
    
    char buffer[100];
    printf("Nota: ");
    fgets(buffer, sizeof(buffer), stdin);
    if (sscanf(buffer, "%f", &r.valor) != 1) {
        r.valor = 0.0f;
    }

    printf("Confirmar salvamento em %s? (s/n): ", arquivoAtual);
    fgets(buffer, sizeof(buffer), stdin);
    confirma = buffer[0];
    if (confirma == 's' || confirma == 'S') {
        FILE *f = fopen(arquivoAtual, "a");
        fprintf(f, "%d|%s|%s|%.2f\n", r.id, r.nome, r.infoExtra, r.valor);
        fclose(f);
        printf(">>> Sucesso: Registro %d salvo!\n", r.id);
    }
}

void listar(char *labelExtra) {
    FILE *f = fopen(arquivoAtual, "r");
    if (!f) { printf("\n[!] Banco de dados vazio ou inexistente.\n"); return; }
    
    printf("\nID    | %-20s | %-15s | Nota\n", "NOME", labelExtra);
    printf("------------------------------------------------------------\n");
    char linha[200];
    while (fgets(linha, sizeof(linha), f)) {
        char *id = strtok(linha, "|");
        char *nome = strtok(NULL, "|");
        char *extra = strtok(NULL, "|");
        char *val = strtok(NULL, "|");
        if (id) printf("%-5s | %-20s | %-15s | %s", id, nome, extra, val);
    }
    fclose(f);
}

