void listarDisciplinas() {
    FILE *f = fopen("disciplinas.txt", "r");
    if (!f) { printf("\n[!] Nenhuma disciplina cadastrada.\n"); return; }
    
    printf("\nID    | %-25s | %-20s | Carga Horaria\n", "DISCIPLINA", "PROFESSOR");
    printf("-----------------------------------------------------------------------\n");
    char linha[200];
    while (fgets(linha, sizeof(linha), f)) {
        int id, carga;
        char nome[50], prof[50];
        if (sscanf(linha, "%d|%49[^|]|%49[^|]|%d", &id, nome, prof, &carga) == 4) {
            printf("%-5d | %-25s | %-20s | %d h\n", id, nome, prof, carga);
        }
    }
    fclose(f);
}

void alterarDisciplina() {
    int idBusca;
    printf("\nDigite o ID da disciplina a alterar: ");
    scanf("%d", &idBusca);
    limparBuffer();

    FILE *f = fopen("disciplinas.txt", "r");
    FILE *temp = fopen("temp_disciplinas.txt", "w");
    if (!f || !temp) { printf("[!] Erro ao abrir arquivo.\n"); return; }

    int id, carga;
    char nome[50], prof[50];
    int encontrado = 0;

    while (fscanf(f, "%d|%49[^|]|%49[^|]|%d", &id, nome, prof, &carga) == 4) {
        if (id == idBusca) {
            encontrado = 1;
            printf("Disciplina: %s\nProfessor: %s\nCarga: %d h\n", nome, prof, carga);
            printf("\nNovo Nome: "); fgets(nome, 50, stdin);
            nome[strcspn(nome, "\n")] = 0;
            printf("Novo Professor: "); fgets(prof, 50, stdin);
            prof[strcspn(prof, "\n")] = 0;
            printf("Nova Carga Horaria: "); scanf("%d", &carga);
            limparBuffer();
        }
        fprintf(temp, "%d|%s|%s|%d\n", id, nome, prof, carga);
    }

    fclose(f);
    fclose(temp);
    remove("disciplinas.txt");
    rename("temp_disciplinas.txt", "disciplinas.txt");

    if (encontrado) printf(">>> Sucesso: Disciplina atualizada!\n");
    else printf("[!] Disciplina nao encontrada.\n");
}

